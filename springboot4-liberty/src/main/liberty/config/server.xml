<?xml version="1.0" encoding="UTF-8"?>
<server description="Spring Boot 4 on OpenLiberty">
    <featureManager>
        <feature>springBoot-4.0</feature>
        <feature>servlet-6.1</feature>
        <feature>expressionLanguage-6.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="8080" />

    <httpOptions maxKeepAliveRequests="-1" />

    <springBootApplication id="springboot4-liberty"
                           location="thin-springboot4-liberty-1.0.jar"
                           name="springboot4-liberty" />
</server>